# Required — no defaults; the server will refuse to start without these
LIBRARIE_SESSION_SECRET=change-me-min-32-chars-random-string
LIBRARIE_ENCRYPTION_KEY=change-me-exactly-32-hex-chars00

# Optional — shown with their default values
# LIBRARIE_PORT=8080
# LIBRARIE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/librarie?sslmode=disable
# LIBRARIE_ADMIN_USERS=admin
# LIBRARIE_STORAGE_PATH=./data/uploads
